# ── Imagem Docker ─────────────────────────────────────────────────────────────
# Prefixo do registry (deixe vazio para imagem local).
# Exemplos: "ghcr.io/seu-usuario/" | "registry.seudominio.com/" | ""
REGISTRY=

# Tag da imagem a ser usada/publicada (ex: 1.0.0, latest, sha-abc1234)
IMAGE_TAG=latest

# ── Domínio ────────────────────────────────────────────────────────────────────
# Domínio público da aplicação (sem https://).
# Usado nas labels do Traefik e nas variáveis de URL da aplicação.
APP_DOMAIN=afiliado.seudominio.com.br

# ── Banco de Dados (PostgreSQL) ────────────────────────────────────────────────
POSTGRES_USER=afiliado
POSTGRES_PASSWORD=troque-por-senha-segura
POSTGRES_HOST=postgres
POSTGRES_DB=afiliado_ml

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=troque-por-senha-segura
REDIS_HOST=redis

# ── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-chave-secreta-longa
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Serviço de Atualização de Preços ─────────────────────────────────────────
# Intervalo em milissegundos (padrão: 6 horas = 21600000)
PRICE_UPDATE_INTERVAL=21600000

# ── SMTP (opcional) ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@seudominio.com.br
